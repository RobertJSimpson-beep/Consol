Sub DeleteQuarterRows()

    Dim tabs As Variant
    Dim ws As Worksheet
    Dim lastRow As Long
    Dim r As Long
    Dim val As String
    Dim t As Variant

    ' Tabs to process
    tabs = Array("Essbase Actuals", "Essbase Forecast", "Essbase Budget")

    For Each t In tabs
        
        On Error Resume Next
        Set ws = Worksheets(t)
        If ws Is Nothing Then
            MsgBox "Sheet not found: " & t
            Err.Clear
            On Error GoTo 0
            GoTo NextSheet
        End If
        On Error GoTo 0
        
        lastRow = ws.Cells(ws.Rows.Count, "A").End(xlUp).Row
        
        ' Loop bottom‑up to safely delete rows
        For r = lastRow To 1 Step -1
            val = Trim(UCase(ws.Cells(r, "A").Value))
            
            If val = "Q1" Or val = "Q2" Or val = "Q3" Or val = "Q4" Then
                ws.Rows(r).Delete
            End If
        Next r
        
NextSheet:
        Set ws = Nothing
    Next t

    MsgBox "Quarter rows deleted from all tabs."

End Sub
