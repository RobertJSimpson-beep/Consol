Sub ZoomAndCleanAll()

    Dim ws As Worksheet
    Dim zoomCells As Variant
    Dim cellRef As Variant
    Dim lastRow As Long
    Dim i As Long

    ' List of sheets to process in order
    Dim sheetsToDo As Variant
    sheetsToDo = Array("Essbase Actuals", "Essbase Forecast")

    ' Cells to zoom into on each sheet
    zoomCells = Array("A4", "C4", "E4")

    For Each ws In ThisWorkbook.Worksheets
        If Not IsError(Application.Match(ws.Name, sheetsToDo, 0)) Then

            ws.Activate

            ' --- Step 1: Zoom to A4 ---
            Range("A4").Select
            ActiveWindow.Zoom = True

            ' --- Step 2: Delete rows where Column A contains "Q" ---
            lastRow = ws.Cells(ws.Rows.Count, "A").End(xlUp).Row

            For i = lastRow To 1 Step -1
                If InStr(1, ws.Cells(i, "A").Value, "Q", vbTextCompare) > 0 Then
                    ws.Rows(i).Delete
                End If
            Next i

            ' --- Step 3: Continue zooming to other cells ---
            For Each cellRef In zoomCells
                ws.Range(cellRef).Select
                ActiveWindow.Zoom = True
            Next cellRef

        End If
    Next ws

End Sub
