    // 1. Group by Merged and sum the YTD column
    #"Grouped Totals" =
        Table.Group(
            #"Removed Other Columns",
            {"Merged"},
            {
                {"TotalYTD", each List.Sum([#"OPEX&RES Dec26 YTD"]), type number}
            }
        ),

    // 2. Calculate the grand total of all YTD values
    #"Added Grand Total" =
        Table.AddColumn(
            #"Grouped Totals",
            "GrandTotal",
            each List.Sum(#"Grouped Totals"[TotalYTD]),
            type number
        ),

    // 3. Add percentage share column
    #"Added Percent Share" =
        Table.AddColumn(
            #"Added Grand Total",
            "PercentShare",
            each [TotalYTD] / [GrandTotal],
            type number
        )
