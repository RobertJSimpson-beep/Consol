    // 1. Group by Merged and sum the YTD column
    #"Grouped Totals" =
        Table.Group(
            #"Removed Other Columns",
            {"Merged"},
            {
                {"TotalYTD", each List.Sum([#"OPEX&RES Dec26 YTD"]), type number}
            }
        ),

    // 2. Merge totals back to the main table
    #"Merged Back Totals" =
        Table.NestedJoin(
            #"Removed Other Columns",
            {"Merged"},
            #"Grouped Totals",
            {"Merged"},
            "GroupData",
            JoinKind.LeftOuter
        ),

    #"Expanded Totals" =
        Table.ExpandTableColumn(
            #"Merged Back Totals",
            "GroupData",
            {"TotalYTD"},
            {"TotalYTD"}
        ),

    // 3. Add percentage split column
    #"Added Percent Split" =
        Table.AddColumn(
            #"Expanded Totals",
            "PercentSplit",
            each [#"OPEX&RES Dec26 YTD"] / [TotalYTD],
            type number
        )
