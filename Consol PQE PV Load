let
    // Load the full source table
    Source = Excel.CurrentWorkbook(){[Name="Table1"]}[Content],

    // Load the selected year from the Excel parameter table
    ParameterYear =
        List.First(
            Excel.CurrentWorkbook(){[Name="Parameter_Year"]}[Content][Year]
        ),

    // Extract Row 1 and Row 2
    Row1 = Record.ToList(Source{0}),
    Row2 = Record.ToList(Source{1}),

    // Forward-fill Row 1 so every column has a cost category
    FilledRow1 =
        List.Accumulate(
            List.Positions(Row1),
            {},
            (state, idx) =>
                let
                    current = Row1{idx},
                    previous = if idx = 0 then current else List.Last(state),
                    value = if current = null or current = "" then previous else current
                in
                    state & {value}
        ),

    // Always keep Columns A:I (positions 0 to 8)
    AlwaysKeep = {0..8},

    // Extract A:I as a small safe table
    FixedCols =
        Table.SelectColumns(
            Source,
            List.Transform(AlwaysKeep, each Table.ColumnNames(Source){_})
        ),

    // Identify date columns by checking Row 2 for valid dates
    DateColumnPositions =
        List.Select(
            List.Positions(Row2),
            each (try Date.From(Row2{_}) otherwise null) <> null
        ),

