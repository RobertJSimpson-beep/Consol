let
    // Load external workbook
    Source = Excel.Workbook(File.Contents("C:\Path\YourFile.xlsx"), null, true),

    // Pick the sheet or table you need
    Raw = Source{[Item="Sheet1", Kind="Sheet"]}[Data],

    // Convert to table
    ToTable = Table.PromoteHeaders(Raw, [PromoteAllScalars=true]),

    // Extract Row 1 (group names) and Row 2 (months)
    Row1 = Raw{0},
    Row2 = Raw{1},

    // Build new headers: "<Month> - <Group>"
    NewHeaders =
        List.Transform(
            List.Zip({Record.ToList(Row2), Record.ToList(Row1)}),
            each Text.Combine(List.Transform(_, Text.From), " - ")
        ),

    // Remove the first two rows (old headers)
    Data = Table.Skip(Raw, 2),

    // Apply new headers
    Renamed =
        Table.RenameColumns(
            Data,
            List.Zip({Table.ColumnNames(Data), NewHeaders}),
            MissingField.Ignore
        )
in
    Renamed
