let
    // Load the full source table
    Source = Excel.CurrentWorkbook(){[Name="Table1"]}[Content],

    // Load the selected year from the Excel parameter table
    ParameterYear =
        List.First(
            Excel.CurrentWorkbook(){[Name="Parameter_Year"]}[Content][Year]
        ),

    // Extract Row 1 and Row 2
    Row1 = Record.ToList(Source{0}),
    Row2 = Record.ToList(Source{1}),

    // Forward-fill Row 1 so every column has a cost category
    FilledRow1 =
        List.Accumulate(
            List.Positions(Row1),
            {},
            (state, idx) =>
                let
                    current = Row1{idx},
                    previous = if idx = 0 then current else List.Last(state),
                    value = if current = null or current = "" then previous else current
                in
                    state & {value}
        ),

    // Identify columns where Row 2's YEAR matches the parameter
    YearColumns =
        List.Select(
            List.Positions(Row2),
            each 
                let
                    v = Row2{_},
                    d = try Date.From(v) otherwise null,
                    y = if d <> null then Date.Year(d) else null
                in
                    y = ParameterYear
        ),

    // Always keep Columns A:I (positions 0 to 8)
    AlwaysKeep = {0..8},

    // Combine the always-keep columns with the year-matched columns
    ColumnsToKeep = List.Union({AlwaysKeep, YearColumns}),

    // Reduce the table BEFORE doing any heavy transformations
    Reduced =
        Table.SelectColumns(
            Source,
            List.Transform(ColumnsToKeep, each Table.ColumnNames(Source){_})
        ),

    // Extract reduced Row 1 and Row 2
    Row1_R = List.Select(FilledRow1, (v, idx) => List.Contains(ColumnsToKeep, idx)),
    Row2_R = List.Select(Row2, (v, idx) => List.Contains(ColumnsToKeep, idx)),

    // Original column names after reduction
    ColNames = Table.ColumnNames(Reduced),

    // Build new combined headers
    NewHeaders =
        List.Transform(
            List.Positions(ColNames),
            each Text.Combine(
                {
                    Text.From(Row1_R{_}),
                    Text.From(Row2_R{_})
                },
                " "
            )
        ),

    // Remove the first two rows (header rows)
    Data = Table.Skip(Reduced, 2),

    // Apply the new headers
    Renamed =
        Table.RenameColumns(
            Data,
            List.Zip({ColNames, NewHeaders})
        )
in
    Renamed
