let
    // Load the full source table
    Source = Excel.CurrentWorkbook(){[Name="Table1"]}[Content],

    // Load the selected year from the Excel parameter table
    ParameterYear =
        List.First(
            Excel.CurrentWorkbook(){[Name="Parameter_Year"]}[Content][Year]
        ),

    // Extract Row 2 (dates) as a list
    Row2 = Record.ToList(Source{1}),

    // Identify column positions where Row 2 contains the selected year (safe version)
    ColumnsToKeep =
        List.Select(
            List.Positions(Row2),
            each 
                let
                    v = Row2{_},
                    t = try Text.From(v) otherwise ""
                in
                    Text.Contains(t, Text.From(ParameterYear))
        ),

    // Reduce the table BEFORE doing any heavy transformations
    Reduced =
        Table.SelectColumns(
            Source,
            List.Transform(ColumnsToKeep, each Table.ColumnNames(Source){_})
        ),

    // Extract the reduced Row 1 and Row 2
    Row1_R = Reduced{0},
    Row2_R = Reduced{1},

    // Build new combined headers: "<Cost Category> <Month> <Year>"
    NewHeaders =
        List.Transform(
            List.Zip({Record.ToList(Row1_R), Record.ToList(Row2_R)}),
            each Text.Combine(List.Transform(_, Text.From), " ")
        ),

    // Remove the first two rows (header rows)
    Data = Table.Skip(Reduced, 2),

    // Apply the new headers
    Renamed =
        Table.RenameColumns(
            Data,
            List.Zip({Table.ColumnNames(Data), NewHeaders})
        )
in
    Renamed
